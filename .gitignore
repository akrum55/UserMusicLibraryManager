# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# ---- Xcode build output ----
build/
DerivedData/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM
*.xcarchive

# Stray build log that got committed before
build.log

# ---- Xcode per-user state ----
# NOTE: must be xcuserdata/ (the directory) — *.xcuserdata does NOT match it.
xcuserdata/
*.xcuserstate

# ---- Swift Package Manager ----
.build/
.swiftpm/
Packages/
# Keep Package.resolved committed for reproducible builds — do NOT ignore it.

# ---- TagLib note ----
# TagLib/ IS intentionally tracked (headers + static libs the app links against).
# Do not add it here.

# ---- Misc ----
*.tmp
.env
